#!/bin/bash
set -e

CONFIG_MK="config.mk"

echo "Detecting build environment..."
echo ""

# --- CUDA toolkit ---
NVCC_PATH=""
if command -v nvcc &>/dev/null; then
    NVCC_PATH="$(command -v nvcc)"
elif [ -x /usr/local/cuda/bin/nvcc ]; then
    NVCC_PATH="/usr/local/cuda/bin/nvcc"
elif [ -x /opt/cuda/bin/nvcc ]; then
    NVCC_PATH="/opt/cuda/bin/nvcc"
fi

if [ -z "$NVCC_PATH" ]; then
    echo "ERROR: nvcc not found. Install the CUDA toolkit or add it to PATH."
    exit 1
fi

CUDA_VERSION=$("$NVCC_PATH" --version | grep -oP 'release \K[0-9]+\.[0-9]+')
echo "  CUDA toolkit: $NVCC_PATH (version $CUDA_VERSION)"

# --- GPU architectures ---
GPU_ARCHES=()
if command -v nvidia-smi &>/dev/null; then
    while IFS= read -r cap; do
        # nvidia-smi returns e.g. "8.6", convert to "86"
        arch=$(echo "$cap" | tr -d '.')
        # Deduplicate
        if [[ ! " ${GPU_ARCHES[*]} " =~ " ${arch} " ]]; then
            GPU_ARCHES+=("$arch")
        fi
    done < <(nvidia-smi --query-gpu=compute_cap --format=csv,noheader,nounits 2>/dev/null)
fi

if [ ${#GPU_ARCHES[@]} -eq 0 ]; then
    echo "  GPUs: none detected (nvidia-smi not available or no GPUs found)"
    echo ""
    echo "ERROR: No GPUs detected. Cannot determine target architecture."
    echo "  You can set it manually:"
    echo "    GPU_GENCODE=\"-gencode arch=compute_86,code=sm_86\" make -j\$(nproc)"
    exit 1
fi

# Build gencode flags
GENCODE_FLAGS=""
for arch in "${GPU_ARCHES[@]}"; do
    GENCODE_FLAGS+="  -gencode arch=compute_${arch},code=sm_${arch} \\\\\n"
done
# Add PTX for forward compatibility using highest arch
HIGHEST_ARCH="${GPU_ARCHES[-1]}"
GENCODE_FLAGS+="  -gencode arch=compute_${HIGHEST_ARCH},code=compute_${HIGHEST_ARCH}"

echo "  GPUs detected:"
# Show GPU names
nvidia-smi --query-gpu=index,name,compute_cap --format=csv,noheader 2>/dev/null | while IFS= read -r line; do
    echo "    $line"
done

# --- CPU cores ---
if command -v nproc &>/dev/null; then
    NPROC=$(nproc)
elif [ -f /proc/cpuinfo ]; then
    NPROC=$(grep -c ^processor /proc/cpuinfo)
elif command -v sysctl &>/dev/null; then
    NPROC=$(sysctl -n hw.ncpu 2>/dev/null || echo 4)
else
    NPROC=4
fi
echo "  CPU cores: $NPROC"

# --- Write config.mk ---
cat > "$CONFIG_MK" << MKEOF
# Generated by ./configure — do not edit
# Re-run ./configure to regenerate

NVCC := ${NVCC_PATH}
NPROC := ${NPROC}
MKEOF

# Write GPU_GENCODE with proper escaping
echo -n "GPU_GENCODE := " >> "$CONFIG_MK"
for arch in "${GPU_ARCHES[@]}"; do
    echo " \\" >> "$CONFIG_MK"
    echo "  -gencode arch=compute_${arch},code=sm_${arch}" >> "$CONFIG_MK"
done
# Overwrite last line to add the PTX entry too
# Actually, let's just build it cleanly
# Remove what we just wrote and redo
head -n 3 "$CONFIG_MK" > "${CONFIG_MK}.tmp"
mv "${CONFIG_MK}.tmp" "$CONFIG_MK"

{
    echo -n "GPU_GENCODE :="
    for arch in "${GPU_ARCHES[@]}"; do
        echo " \\"
        echo -n "  -gencode arch=compute_${arch},code=sm_${arch}"
    done
    echo " \\"
    echo "  -gencode arch=compute_${HIGHEST_ARCH},code=compute_${HIGHEST_ARCH}"
} >> "$CONFIG_MK"

echo ""
echo "Wrote $CONFIG_MK"
echo ""
echo "Ready to build:"
echo "  make -j${NPROC}"
